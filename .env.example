# Path of Exile Monitor Configuration

# Your POESESSID cookie from pathofexile.com (do not share this!)
POESESSID=your_poesessid_here

# Ntfy configuration
NTFY_URL=http://your-ntfy-server-ip:port
NTFY_TOPIC=poe-alerts

# PoE League to monitor
POE_LEAGUE=Runes of Aldur

# Check interval in minutes (default: 30)
CHECK_INTERVAL=30

# Timezone (e.g., Europe/Berlin)
TZ=Europe/Berlin

# The query hash/ID of your PoE Trade search for your active shop listings (from the trade URL)
# Example: If your shop search URL is https://www.pathofexile.com/trade2/search/poe2/league/your_search_id, use:
TRADE_SEARCH_ID=your_trade_search_id_here
